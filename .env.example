# 主管侧 .env（服务端 + 查询脚本）
DB_HOST=10.100.0.176
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=向主管填写
DB_NAME=cursor_team_reports

# API 服务（同事 POST 到此地址 —— 必须是公网 HTTPS，不能填 10.100.x.x）
# 示例：https://cursor-reports.yourdomain.com  或  https://xxxx.trycloudflare.com（临时）
REPORT_API_URL=https://YOUR-PUBLIC-API-URL
API_HOST=127.0.0.1
API_PORT=8080

# 固定 Cloudflare Tunnel 配置（正式环境，见 docs/公网部署指南.md）
# CLOUDFLARE_TUNNEL_CONFIG=D:/cursor-team-daily-report/config/cloudflare-tunnel.yml

